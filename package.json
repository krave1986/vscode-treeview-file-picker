{
    "name": "vscode-treeview-file-picker",
    "displayName": "TreeView File Picker",
    "description": "A VS Code extension starter for building a workspace file selector using the native TreeView API — with checkboxes, cascade selection, glob filtering, and theme-aware icons.",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./src/extension.js",
    "contributes": {
        "configuration": {
            "title": "TreeView File Picker",
            "properties": {
                "tvfp.include": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/*"
                    ],
                    "description": "Glob patterns for files to show in the file selector."
                },
                "tvfp.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/.git/",
                        "**/node_modules/",
                        "**/dist/",
                        "**/build/",
                        "**/.vscode/",
                        "**/*.vsix"
                    ],
                    "description": "Glob patterns for files to hide from the file selector."
                },
                "tvfp.collapse": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Glob patterns for directories to collapse by default."
                }
            }
        },
        "views": {
            "tvfp-panel": [
                {
                    "id": "tvfp.fileSelector",
                    "name": "File Selector",
                    "type": "tree",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "tvfp-panel",
                    "title": "TreeView File Picker",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "commands": []
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.116.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.3"
    },
    "dependencies": {
        "picomatch": "^4.0.4"
    }
}
